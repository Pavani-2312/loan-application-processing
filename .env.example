# Copy this file to .env and fill in your values
# Never commit .env to version control

# OpenRouter API key (https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use via OpenRouter (Claude 3.5 Sonnet recommended)
LLM_MODEL=anthropic/claude-3.5-sonnet

# OpenRouter base URL (do not change)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Local data directory (SQLite DB + Chroma persistent store)
DATA_DIR=./data

# SQLite database filename (relative to DATA_DIR)
DB_FILENAME=loan_applications.db

# Chroma persistent directory name (relative to DATA_DIR)
CHROMA_DIR=chroma_store

# Per-node LLM call timeout in seconds (default 30)
NODE_TIMEOUT_SECONDS=30
