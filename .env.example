# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# LLM Provider — GitHub Models (uses your GitHub Personal Access Token)
#
# 1. Generate a PAT at https://github.com/settings/tokens
#    Scopes needed: none beyond the default (GitHub Models is PAT-gated,
#    no special scope required for the inference endpoint).
# 2. Paste the token as GITHUB_TOKEN below.
# 3. Choose a model from https://github.com/marketplace/models
#    Recommended: openai/gpt-4o  or  meta/meta-llama-3.1-405b-instruct
# ---------------------------------------------------------------------------
GITHUB_TOKEN=your_github_personal_access_token_here

# Model name exactly as listed on https://github.com/marketplace/models
# Use the plain model ID — no provider prefix (e.g. gpt-4o, not openai/gpt-4o)
LLM_MODEL=gpt-4o

# GitHub Models inference endpoint (do not change)
OPENROUTER_BASE_URL=https://models.inference.ai.azure.com

# ---------------------------------------------------------------------------
# Local storage
# ---------------------------------------------------------------------------
DATA_DIR=./data
DB_FILENAME=loan_applications.db
CHROMA_DIR=chroma_store

# Per-node LLM call timeout in seconds
NODE_TIMEOUT_SECONDS=60
