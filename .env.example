# GitHub Personal Access Token — https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_heres

# Model name from https://github.com/marketplace/models
LLM_MODEL=gpt-4o

# GitHub Models inference endpoint
OPENROUTER_BASE_URL=https://models.inference.ai.azure.com

# Local storage
DATA_DIR=./data
DB_FILENAME=loan_applications.db
CHROMA_DIR=chroma_store

# Per-node LLM call timeout in seconds
NODE_TIMEOUT_SECONDS=60
